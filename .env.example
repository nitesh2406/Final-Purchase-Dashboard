# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# Google Apps Script Web App Integration
# Target Google Apps Script Web App Endpoint URL
VITE_APPS_SCRIPT_URL="https://script.google.com/macros/s/AKfycbxoKgOCvBAcIzYzcqj0WA_1Y37XF7AZdvZi3aBNpFttlYgTGmRagmtKDhXMysXUOppEPw/exec"

# Set to true to bypass the login screen (dev only). Defaults to false if not set.
VITE_TEST_LOGIN_BYPASS=false

# Google Drive backend storage (Vendor Shipment document uploads)
# Create an OAuth 2.0 Client (type: Web application) in Google Cloud Console
# with the Drive API enabled, then grant it access to the target Drive owner's
# account once via GET /api/drive/oauth/authorize -> /api/drive/oauth/callback,
# and paste the resulting refresh token below.
GOOGLE_DRIVE_REFRESH_TOKEN="MY_GOOGLE_DRIVE_REFRESH_TOKEN"


# Dev/testing only: when true, "Finalize & Record Shipment" in the Vendor
# Shipments wizard skips the Apps Script call that writes Sheets data
# (Batches/Vendor_Shipments/Purchase_Orders/etc.) and only exercises the
# Google Drive document upload. Leave false/unset in normal use.
VITE_DEV_MODE_SKIP_SHIPMENT_WRITE=false
